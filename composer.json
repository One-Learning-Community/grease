{
    "name": "onelearningcommunity/grease",
    "description": "Opt-in performance optimizations for Eloquent's hot path — the wins upstream won't merge. Zero core changes, byte-identical output.",
    "keywords": ["laravel", "eloquent", "performance", "orm", "optimization"],
    "homepage": "https://github.com/onelearningcommunity/grease",
    "license": "MIT",
    "authors": [
        {
            "name": "Dan Krieger",
            "email": "dan@onelearningcommunity.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/events": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpbench/phpbench": "^1.2",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Grease\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Grease\\Tests\\": "tests/",
            "Grease\\Bench\\": "benchmarks/Bench/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "bench": "phpbench run --report=aggregate",
        "bench:suite": "phpbench run benchmarks/Bench/SuiteBench.php --report=aggregate"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpbench/phpbench": false
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
