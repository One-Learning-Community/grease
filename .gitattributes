# Keep the distributed package lean — exclude dev-only paths from the
# `composer require` dist archive. GitHub/Packagist honor export-ignore.
# NB: this strips files from the installed dist tarball only; it does NOT
# hide them from the GitHub repo or Packagist's source listing.
/.github          export-ignore
/.gitattributes   export-ignore
/.gitignore       export-ignore
/benchmarks       export-ignore
/docs             export-ignore
/storage          export-ignore
/tests            export-ignore
/phpbench.json    export-ignore
/phpunit.xml.dist export-ignore
/*.md             export-ignore
