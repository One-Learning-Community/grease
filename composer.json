{
    "name": "onelearningcommunity/grease",
    "description": "Opt-in performance optimizations for Eloquent's hot path, built from optimizations declined upstream. Zero core changes, byte-identical output.",
    "keywords": ["laravel", "eloquent", "performance", "orm", "optimization"],
    "homepage": "https://github.com/One-Learning-Community/grease",
    "support": {
        "issues": "https://github.com/One-Learning-Community/grease/issues",
        "source": "https://github.com/One-Learning-Community/grease",
        "docs": "https://one-learning-community.github.io/grease/"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Dan Krieger",
            "email": "dan@onelearningcommunity.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/events": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/view": "^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "livewire/livewire": "^3.0",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpbench/phpbench": "^1.2",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Grease\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Grease\\Tests\\": "tests/",
            "Grease\\Bench\\": "benchmarks/Bench/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "pint",
        "lint:test": "pint --test",
        "bench": "phpbench run --report=aggregate",
        "bench:suite": "phpbench run benchmarks/Bench/SuiteBench.php --report=aggregate"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpbench/phpbench": false
        }
    },
    "prefer-stable": true
}
